{
  "name": "@arcade-swarm/visual",
  "version": "0.1.0",
  "description": "Shared retro visual effects (CRT scanlines, phosphor glow, screen shake) for Arcade Swarm games.",
  "type": "module",
  "main": "src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    }
  },
  "scripts": {
    "test": "vitest",
    "test:run": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "typescript": "^5.4.0",
    "vitest": "^2.0.0"
  },
  "keywords": ["visual", "crt", "retro", "arcade-swarm"]
}
