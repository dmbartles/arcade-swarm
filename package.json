{
  "name": "arcade-swarm",
  "version": "0.1.0",
  "private": true,
  "description": "Monorepo of educational HTML5 arcade games built with Phaser.js 3, aligned to Common Core math standards.",
  "workspaces": [
    "games/*",
    "shared/*"
  ],
  "scripts": {
    "test": "npm run test --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "build": "npm run build --workspaces --if-present"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  }
}
