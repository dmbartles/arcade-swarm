# Normalize line endings to LF in the repository, checkout as-is on all platforms
* text=auto eol=lf

# Force LF for shell scripts and Python
*.py text eol=lf
*.sh text eol=lf
*.yml text eol=lf
*.yaml text eol=lf

# Force LF for web assets
*.js text eol=lf
*.ts text eol=lf
*.json text eol=lf
*.md text eol=lf
*.html text eol=lf
*.css text eol=lf

# Treat binary assets as binary (no line ending conversion)
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.ico binary
*.mp3 binary
*.ogg binary
*.wav binary
*.woff binary
*.woff2 binary
*.ttf binary
